{
  "name": "@matheussartori/hackerchat-client",
  "version": "1.0.1",
  "description": "The hackerchat client allows you to connect to any hackerchat server, directly on the shell.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hackerchat": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "eslint src",
    "test:ci": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "chat",
    "websocket",
    "terminal",
    "nodejs",
    "node"
  ],
  "author": {
    "name": "Matheus Sartori",
    "email": "ms.sartori@outlook.com.br",
    "url": "https://github.com/matheussartori"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "figures": "^6.1.0",
    "ink": "^7.0.4",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "neostandard": "^0.13.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
